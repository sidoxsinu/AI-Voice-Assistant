# ─────────────────────────────────────────────
# EXAMPLE .env — copy this to .env and fill in your real values
# Never commit your real .env to version control!
# ─────────────────────────────────────────────

# Speech-to-text: local (faster-whisper) or google (Cloud Speech-to-Text — live captions, billing).
# STT_PROVIDER=google
# Create a service account with "Cloud Speech User", download JSON, then either:
#   export GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/key.json
# or set in .env (server loads it into the environment if you use a tool that reads .env):
# GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/key.json
# BCP-47 list: first = primary (e.g. Malayalam), up to 3 alternates.
# GOOGLE_STT_LANGUAGES=ml-IN,en-IN,hi-IN

# 16 GB Apple Silicon (e.g. MacBook Air): use large-v3 for best Malayalam STT; leave
# compute/thread defaults unset so server.py applies Apple Silicon tuning.
# 8 GB machines: prefer medium or distil-large-v3 instead.

# Local speech-to-text (faster-whisper). Larger models = better Malayalam, more RAM/CPU.
# Examples: tiny, base, small, medium, large-v2, large-v3, distil-large-v3
WHISPER_MODEL_SIZE=large-v3

# Optional: force Whisper language (skips autodetect). Use ml for Malayalam-first workflows.
# Leave empty for automatic detection.
# WHISPER_LANGUAGE=ml

# Whisper runtime (optional — Apple Silicon defaults are applied when unset, see README)
# WHISPER_DEVICE=auto
# WHISPER_COMPUTE_TYPE=int8
# Thread count for CPU inference; on Mac ARM we default to (logical_cores - 2), capped at 12.
# WHISPER_CPU_THREADS=6

# Live partial captions re-run STT on growing WebM; can show junk while recording.
# 0 = only decode once when you stop (recommended). 1 = interim transcripts every ~1s.
WHISPER_LIVE_PARTIALS=0

# TTS: edge = Microsoft neural voices (better Malayalam), gtts = Google TTS only
TTS_ENGINE=edge
EDGE_TTS_VOICE_ML=ml-IN-SobhanaNeural
EDGE_TTS_VOICE_HI=hi-IN-SwaraNeural
EDGE_TTS_VOICE_EN=en-IN-NeerjaNeural

# API Keys for Cloud services
GEMINI_API_KEY=your_gemini_api_key_here
GROQ_API_KEY=your_groq_api_key_here

# Gmail address — the account used to send emails
GMAIL_USER=your_email@gmail.com

# Gmail App Password — NOT your regular Gmail password!
# Generate one at: https://myaccount.google.com/apppasswords
# (Requires 2-Step Verification to be enabled on your Google account)
# Format is typically: xxxx xxxx xxxx xxxx  (4 groups of 4 letters)
GMAIL_PASS=xxxx xxxx xxxx xxxx
